# Database connection string for local dev.
# If the backend runs inside Docker Compose, use the MySQL service name instead of localhost.
# Local host example:
# DATABASE_URL="mysql://root:your_password_here@localhost:3306/joystick_junction"
# Docker Compose example:
# DATABASE_URL="mysql://root:your_password_here@mysql:3306/joystick_junction"
DATABASE_URL="mysql://root:your_password_here@localhost:3306/joystick_junction"

# API port (use 4000 locally so Next.js can use 3000). Hosting usually sets PORT for you.
PORT=4000
JWT_SECRET="generate-a-long-random-string"
# Allowed browser origins for CORS, comma-separated.
# Example: http://localhost:3000
CORS_ORIGIN="http://localhost:3000"
